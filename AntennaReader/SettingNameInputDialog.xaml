<Window x:Class="AntennaReader.SettingNameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Setting Name" Height="140" Width="340"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Preference name:" Style="{StaticResource FormLabel}"/>
        <TextBox Grid.Row="1" x:Name="NameBox" Style="{StaticResource StandardInput}"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Style="{StaticResource StandardBtn}" Click="Cancel_Click"/>
            <Button Content="OK" Style="{StaticResource StandardBtn}" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
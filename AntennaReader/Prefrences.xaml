<Window x:Class="AntennaReader.Prefrences"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AntennaReader"
        mc:Ignorable="d"
        Title="Prefrences" 
        Height="450" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Saved Preferences" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

        <DataGrid Grid.Row="1" x:Name="PreferenceList"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Log Scale" Binding="{Binding IsLogScale}" Width="*"/>
                <DataGridTextColumn Header="Lower" Binding="{Binding lowerBound}" Width="*"/>
                <DataGridTextColumn Header="Upper" Binding="{Binding upperBound}" Width="*"/>
                <DataGridTextColumn Header="Step" Binding="{Binding ContourStep}" Width="*"/>
                <DataGridTextColumn Header="Modified" Binding="{Binding LastModified}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Apply" Width="90" Height="28" Margin="0,0,8,0" Click="Apply_Click"/>
            <Button Content="Edit..." Width="90" Height="28" Margin="0,0,8,0" Click="Edit_Click"/>
            <Button Content="Rename..." Width="90" Height="28" Margin="0,0,8,0" Click="Rename_Click"/>
            <Button Content="Delete" Width="90" Height="28" Margin="0,0,8,0" Click="Delete_Click"/>
            <Button Content="Close" Width="90" Height="28" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>

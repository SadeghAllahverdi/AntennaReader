<Window x:Class="AntennaReader.Prefrences"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagram Preferences" 
        Height="500" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBox x:Name="SearchBar"
                     Style="{StaticResource StandardInput}"
                     Height="28"
                     Padding="6,0,6,0"
                     TextChanged="SearchBar_TextChanged"
                     Margin="0"/>

            <TextBlock Text="Search (e.g. Preference Name)"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource HintText}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBar}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <ListView x:Name="PreferenceList"
                  Grid.Row="1"
                  Margin="0,0,0,10"
                  SelectionMode="Single">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Apply Preference" Click="Apply_Click"/>
                    <MenuItem Header="Edit Settings" Click="Edit_Click"/>
                    <MenuItem Header="Rename" Click="Rename_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Log Scale" Width="70" DisplayMemberBinding="{Binding IsLogScale}" />
                    <GridViewColumn Header="Lower" Width="60" DisplayMemberBinding="{Binding lowerBound}" />
                    <GridViewColumn Header="Upper" Width="60" DisplayMemberBinding="{Binding upperBound}" />
                    <GridViewColumn Header="Step" Width="50" DisplayMemberBinding="{Binding ContourStep}" />

                    <GridViewColumn Header="Sat Thresh" Width="80" DisplayMemberBinding="{Binding ImageSaturationThreshold}" />
                    <GridViewColumn Header="Dark Thresh" Width="80" DisplayMemberBinding="{Binding ImageDarkThreshold}" />
                    <GridViewColumn Header="Harmonics" Width="80" DisplayMemberBinding="{Binding FourierHarmonics}" />
                    <GridViewColumn Header="DP Eps" Width="60" DisplayMemberBinding="{Binding DpEpsilon}" />
                    <GridViewColumn Header="DP Sync" Width="70" DisplayMemberBinding="{Binding DpSyncInterval}" />

                    <GridViewColumn Header="Modified" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LastModified, StringFormat={}{0:g}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Apply" Style="{StaticResource StandardBtn}" Click="Apply_Click"/>
            <Button Content="Edit..." Style="{StaticResource StandardBtn}" Click="Edit_Click"/>
            <Button Content="Rename..." Style="{StaticResource StandardBtn}" Click="Rename_Click"/>
            <Button Content="Close" Style="{StaticResource StandardBtn}" Click="Close_Click"/>
            <Button Content="Delete" Style="{StaticResource DangerBtn}" Click="Delete_Click"/>
        </StackPanel>
    </Grid>
</Window>
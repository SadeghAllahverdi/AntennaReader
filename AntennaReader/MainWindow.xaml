<Window x:Class="AntennaReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AntennaReader"
        mc:Ignorable="d"
        Title="PlotLeser"
        Height="800" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{x:Static local:MainWindow.OpenImageCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{x:Static local:MainWindow.DeleteBackgroundImageFromCanvasCommand}"/>

        <KeyBinding Key="O" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.OpenDBCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.SaveDBCommand}"/>

        <KeyBinding Key="L" Modifiers="Ctrl" Command="{x:Static local:MainWindow.LockDiagramCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{x:Static local:MainWindow.ToggleScaleModeCommand}"/>

        <KeyBinding Key="H" Modifiers="Ctrl" Command="{x:Static local:MainWindow.AutoExtractCurveSPCommand}"/>
        <KeyBinding Key="H" Modifiers="Ctrl+Alt" Command="{x:Static local:MainWindow.AutoExtractCurveSPDebugCommand}"/>
        <KeyBinding Key="J" Modifiers="Ctrl" Command="{x:Static local:MainWindow.AutoExtractCurveFourierCommand}"/>
        <KeyBinding Key="J" Modifiers="Ctrl+Alt" Command="{x:Static local:MainWindow.AutoExtractCurveFourierDebugCommand}"/>

        <KeyBinding Key="B" Modifiers="Shift" Command="{x:Static local:MainWindow.LabelForMLCommand}"/>

        <KeyBinding Key="D" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.DeleteDiagramCommand}"/>
        <KeyBinding Key="P" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.DeletePointsCommand}"/>

        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{x:Static local:MainWindow.UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{x:Static local:MainWindow.RedoCommand}"/>

        <KeyBinding Key="M" Modifiers="Ctrl" Command="{x:Static local:MainWindow.OpenSettingsCommand}"/>
        <KeyBinding Key="M" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.OpenPreferencesCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Panel.ZIndex="1">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="AntennaNameText"
                   DockPanel.Dock="Right"
                   Margin="12,0,12,0"
                   VerticalAlignment="Center"
                   Foreground="Black"
                   FontWeight="Bold"
                   Text="No antenna loaded"/>

                <TextBlock x:Name="LockStatusText"
                   DockPanel.Dock="Right"
                   Margin="12,0,12,0"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Foreground="Green"
                   Text="Unlocked"/>

                <Menu DockPanel.Dock="Left"
              Background="White"
              Foreground="Black">
                    <MenuItem Header="File">
                        <MenuItem Header="Open Image (Ctrl + O)" Click="OpenImage_Click"/>
                        <MenuItem Header="Delete Image (Ctrl + D)" Click="DeleteBackgroundImageFromCanvas_Click"/>
                        <Separator/>
                        <MenuItem Header="Open Image Folder" Click="OpenImageFolder_Click"/>
                        <MenuItem Header="Open Debug Folder" Click="OpenDebugFolder_Click"/>
                        <MenuItem Header="Open Extract Folder" Click="OpenExportFolder_Click"/>
                    </MenuItem>

                    <MenuItem Header="Database">
                        <MenuItem Header="Open Database Browser (Ctrl + Shift + O)" Click="OpenDB_Click"/>
                        <MenuItem Header="Save to Database (Ctrl + Shift + S)" Click="SaveDB_Click"/>
                    </MenuItem>

                    <MenuItem Header="Diagram">
                        <MenuItem x:Name="LockButton" Header="Lock (Ctrl + L)" Click="LockDiagram_Click"/>
                        <Separator/>
                        <MenuItem Header="Auto Extract Curve (Ctrl + H)" Click="AutoExtractCurveSP_Click"/>
                        <MenuItem Header="Auto Extract Curve (Ctrl + Alt + H)" Click="AutoExtractCurveSPDebug_Click"/>
                        <MenuItem Header="Auto Extract Curve (Ctrl + J)" Click="AutoExtractCurveFourier_Click"/>
                        <MenuItem Header="Auto Extract Curve (Ctrl + Alt + J)" Click="AutoExtractCurveFourierDebug_Click"/>
                        <Separator/>
                        <MenuItem Header="Label For ML Training" Click="LabelForML_Click"/>
                        <Separator/>
                        <MenuItem x:Name="EqoDistButton" Header="Toggle Scale Mode (Ctrl + F)" Click="ToggleScaleMode_Click"/>
                        <MenuItem Header="Delete (Ctrl + Shift + D)" Click="DeleteDiagram_Click"/>
                        <MenuItem Header="Delete All Points (Ctrl + Shift + P)" Click="DeletePoints_Click"/>
                        <MenuItem Header="Diagram Settings... (Ctrl + M)" Click="OpenSettings_Click"/>
                        <MenuItem Header="Manage Preferences... (Ctrl + Shift + M)" Click="OpenPreferences_Click"/>
                    </MenuItem>

                    <MenuItem Header="Interpolation Mode">
                        <MenuItem Header="Monotone"    Click="InterpMode_Click" Tag="Monotone"/>
                        <MenuItem Header="Linear"      Click="InterpMode_Click" Tag="Linear"/>
                        <MenuItem Header="Catmull-Rom" Click="InterpMode_Click" Tag="CatmullRom"/>
                        <MenuItem Header="Lagrange"    Click="InterpMode_Click" Tag="Lagrange"/>
                    </MenuItem>

                    <MenuItem Header="Actions">
                        <MenuItem Header="Undo (Ctrl + Z)" Click="Undo_Click"/>
                        <MenuItem Header="Redo (Ctrl + Y)" Click="Redo_Click"/>
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>
        
        <local:DrawingCanvas x:Name="drawingCanvas"
                             Grid.Row="1"
                             Background="DimGray"
                             Visibility="Visible"/>
    </Grid>
</Window>
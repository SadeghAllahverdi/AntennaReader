<Window x:Class="AntennaReader.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagram Settings"
        Height="540" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Scale Mode" FontWeight="Bold" Margin="0,0,0,6"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
            <RadioButton x:Name="LogScaleRadio" Content="Logarithmic" Margin="0,0,16,0" Checked="ScaleMode_Changed"/>
            <RadioButton x:Name="LinearScaleRadio" Content="Equal-Distance" Checked="ScaleMode_Changed"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="dB Range" FontWeight="Bold" Margin="0,0,0,6"/>
        <Grid Grid.Row="3" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Lower:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="1" x:Name="LowerBoundBox" TextChanged="BoundsTextBox_TextChanged"/>
            <TextBlock Grid.Column="3" Text="Upper:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="4" x:Name="UpperBoundBox" TextChanged="BoundsTextBox_TextChanged"/>
        </Grid>
        <TextBlock Grid.Row="4" x:Name="DbHintText"
                   Foreground="Gray" FontSize="11"
                   Margin="0,0,0,14"
                   Text="Log mode forces Lower = 0"/>

        <TextBlock Grid.Row="5" x:Name="ContourStepLabel" Text="Contour Step (Equal-Distance only)" FontWeight="Bold" Margin="0,0,0,6"/>
        <ComboBox Grid.Row="6" x:Name="ContourStepCombo"
                  SelectionChanged="ContourStepCombo_SelectionChanged"
                  Margin="0,0,0,14"/>

        <TextBlock Grid.Row="7" Text="Export Precision" FontWeight="Bold" Margin="0,0,0,6"/>
        <Grid Grid.Row="8" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="CSV:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="1" x:Name="CsvPrecisionCombo" SelectionChanged="PrecisionCombo_SelectionChanged"/>
            <TextBlock Grid.Column="3" Text="PAT:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="4" x:Name="PatPrecisionCombo" SelectionChanged="PrecisionCombo_SelectionChanged"/>
        </Grid>

        <GroupBox Grid.Row="9" Margin="0,0,0,14" Padding="8,12,8,8">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Danger Zone: Advanced Algorithm Tuning" FontWeight="SemiBold" Foreground="Red"/>
                    <TextBlock x:Name="InlineErrorLabel" 
                               Text=" (Math Failing: Reset to defaults if stuck!)" 
                               Foreground="DarkOrange" 
                               FontWeight="Bold"
                               Margin="5,0,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Black"/>
                    </Style>
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Color Filter:" FontWeight="Normal" VerticalAlignment="Center" Margin="0,0,6,10" ToolTip="Filters out background noise based on color saturation (0-255)."/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="SatThreshBox" TextChanged="TuningTextBox_TextChanged" Margin="0,0,0,10" ToolTip="Default: 40"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Darkness Filter:" FontWeight="Normal" VerticalAlignment="Center" Margin="0,0,6,10" ToolTip="Filters out light shadows. Higher values require darker ink (0-255)."/>
                <TextBox Grid.Row="0" Grid.Column="4" x:Name="DarkThreshBox" TextChanged="TuningTextBox_TextChanged" Margin="0,0,0,10" ToolTip="Default: 100"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Path Smoothing:" FontWeight="Normal" VerticalAlignment="Center" Margin="0,0,6,10" ToolTip="How aggressively to remove redundant points on flat lines. (e.g., 1.8)"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="DpEpsilonBox" TextChanged="TuningTextBox_TextChanged" Margin="0,0,0,10" ToolTip="Default: 1.8"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="Sync Interval:" FontWeight="Normal" VerticalAlignment="Center" Margin="0,0,6,10" ToolTip="Forces the pathfinder to save a coordinate every X degrees, even if the line is smooth."/>
                <TextBox Grid.Row="1" Grid.Column="4" x:Name="DpSyncBox" TextChanged="TuningTextBox_TextChanged" Margin="0,0,0,10" ToolTip="Default: 30"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Curve Flexibility:" FontWeight="Normal" VerticalAlignment="Center" Margin="0,0,6,0" ToolTip="How tightly the wave bends to fit the points. High = jagged, Low = smooth (e.g., 10-15)."/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="HarmonicsBox" TextChanged="TuningTextBox_TextChanged" ToolTip="Default: 15"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save as Preference..." Width="150" Height="28" Margin="0,0,8,0" Click="SaveAsPreference_Click"/>
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Done" Width="80" Height="28" Click="Done_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
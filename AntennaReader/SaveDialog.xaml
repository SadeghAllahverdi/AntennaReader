<Window x:Class="AntennaReader.SaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Antenna" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Antenna Name*:" Foreground="Red" Style="{StaticResource FormLabel}"/>
        <StackPanel Grid.Row="0" Grid.Column="1">
            <TextBox x:Name="AntennaNameBox" Style="{StaticResource StandardInput}" ToolTip="Required"/>
            <TextBlock Text="Format: antennaID_stationName" Style="{StaticResource HintText}" Margin="2,-4,0,8"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Owner:" Style="{StaticResource FormLabel}"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="OwnerBox" Style="{StaticResource StandardInput}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="State:" Style="{StaticResource FormLabel}"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="StateBox" Style="{StaticResource StandardInput}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="City:" Style="{StaticResource FormLabel}"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="CityBox" Style="{StaticResource StandardInput}"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" IsCancel="True" Style="{StaticResource StandardBtn}"/>
            <Button Content="Save" IsDefault="True" x:Name="SaveButton" Click="Save_Click" Style="{StaticResource StandardBtn}"/>
        </StackPanel>
    </Grid>
</Window>